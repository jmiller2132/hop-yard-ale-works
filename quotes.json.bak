[
  { "quote": "Without question the greatest invention in the history of mankind is beer. Oh, I grant you that the wheel was also a fine invention, but the wheel does not go nearly as well with pizza.", "author": "Dave Barry", "weight": 2, "pinFirst": true },
  { "quote": "I love my beer cold, my pizza hot, and my friends always.", "author": "Dave Barry", "weight": 1 },
  { "quote": "Work is the curse of the drinking classes.", "author": "Oscar Wilde" },
  { "quote": "The problem with the world is that everyone is a few drinks behind.", "author": "Humphrey Bogart" },
  { "quote": "Good people drink good beer.", "author": "Hunter S. Thompson" },
  { "quote": "Every pizza is a personal pizza if you try hard and believe in yourself.", "author": "Bill Murray" },
  { "quote": "Unless you are a pizza, the answer is yes, I can live without you.", "author": "Bill Murray" },
  { "quote": "Ideas are like pizza dough, made to be tossed around.", "author": "Anna Quindlen" },
  { "quote": "Beauty is in the eye of the beer holder.", "author": "Kinky Friedman" },
  { "quote": "I can't turn water into wine, but I can turn pizza into breakfast.", "author": "Anonymous" },
  { "quote": "Nothing ever tasted better than a cold beer on a beautiful afternoon with nothing to look forward to than more of the same.", "author": "Hugh Hood" },
  { "quote": "I never drink water because of the disgusting things that fish do in it.", "author": "W.C. Fields" },
  { "quote": "On Venus you could cook a 16-inch pepperoni pizza in seven seconds, just by holding it out to the air. (Yes, I did the math.)", "author": "Neil deGrasse Tyson" },
  { "quote": "What do you call a person who eats a lot of pizza? A pizzaholic.", "author": "Dads Everywhere" },
  { "quote": "I love pizza, meaning: even when I'm in the middle of eating pizza, I wish I were eating pizza.", "author": "Jandy Nelson" },
  { "quote": "You better cut the pizza in four pieces because I'm not hungry enough to eat six.", "author": "Yogi Berra" },
  { "quote": "Beer is proof that God loves us and wants us to be happy.", "author": "Benjamin Franklin" },
  { "quote": "What care I how time advances? I am drinking ale today.", "author": "Edgar Allan Poe" },
  { "quote": "A fine beer may be judged with only one sip, but it's better to be thoroughly sure.", "author": "Czech Proverb" },
  { "quote": "And what is civilisation if it isn't people talking to each other over a goddamned beer?", "author": "James S.A. Corey" },
  { "quote": "We brewers don't make beer, we just get all the ingredients together and the beer makes itself.", "author": "Fritz Maytag" },
  { "quote": "I work until beer o'clock.", "author": "Stephen King" },
  { "quote": "Beer makes you feel the way you ought to feel without beer.", "author": "Henry Lawson" },
  { "quote": "Time is money, money is power, power is pizza, and pizza is knowledge, let's go!", "author": "Aubrey Plaza" },
  { "quote": "I believe this would be a good time for a beer.", "author": "Franklin D. Roosevelt" }
]
